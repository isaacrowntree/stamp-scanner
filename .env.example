# Copy to .env.local and fill in the values you want.
# run.sh auto-loads .env.local into the environment.

# HuggingFace token — needed to download facebook/sam3 weights on first run.
# Get from https://huggingface.co/settings/tokens (Edit token → enable
# "Read access to contents of all public gated repos you can access"),
# after approval at https://huggingface.co/facebook/sam3
HF_TOKEN=

# Colnect catalogue API — free for non-commercial use.
# Apply at https://colnect.com/en/help/collecting/colnect_api
# You receive an API_KEY (URL path) and usually a secret (HMAC-signs requests).
# If Colnect only issues a single credential, leave SECRET blank; the lookup
# tool falls back to signing with the key itself.
COLNECT_API_KEY=
COLNECT_API_SECRET=
